lemma consistency_fido_recovery:
  all-traces
  "∀ A fido_rec #i.
    (((A_Recovers_FIDO_Key( A, fido_rec ) @ #i) ∧
      (¬(∃ #k. LtkRevealUser( A ) @ #k))) ∧
     (¬(∃ Peer #i_init #k_rev.
         (Initiated( A, Peer ) @ #i_init) ∧ (LtkRevealPeer( Peer ) @ #k_rev)))) ⇒
    (∃ #j. (A_Generates_FIDO_Key( A, fido_rec ) @ #j) ∧ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ A fido_rec #i.
  (A_Recovers_FIDO_Key( A, fido_rec ) @ #i)
 ∧
  (∀ #k. (LtkRevealUser( A ) @ #k) ⇒ ⊥) ∧
  (∀ Peer #i_init #k_rev.
    (Initiated( A, Peer ) @ #i_init) ∧ (LtkRevealPeer( Peer ) @ #k_rev)
   ⇒
    ⊥) ∧
  (∀ #j. (A_Generates_FIDO_Key( A, fido_rec ) @ #j) ⇒ ¬(#j < #i))"
*/
simplify
solve( State_A_Recovered( $A, $B, aenc(x, pk(reconstructed_ltk)),
                          reconstructed_ltk
       ) ▶₀ #i )
  case Initiator_Reconstructs_PrivateKey
  solve( P2P_Rcv( $A, $B, <'7_p2p_help', ~nonce> ) ▶₀ #vr.8 )
    case P2P_Receive
    solve( C2S_Rcv( $A, 'Server', <'3_store_pkg', pkA, sk2.2, cipher, $B>
           ) ▶₀ #vr.18 )
      case C2S_Receive
      solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B> ) ▶₀ #vr.20 )
        case C2S_Receive
        solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B> ) ▶₀ #vr.30 )
          case C2S_Receive
          solve( splitEqs(1) )
            case split
            solve( splitEqs(3) )
              case split
              solve( !KU( ~nonce ) @ #vk.9 )
                case Server_Sends_Recovery_Data_case_1
                solve( C2S_Rcv( $A, 'Server',
                                <'3_store_pkg', pkA, sk2, encrypted_sk1, $B>
                       ) ▶₀ #vr.44 )
                  case C2S_Receive
                  solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B.1> ) ▶₀ #vr.55 )
                    case C2S_Receive
                    solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B> ) ▶₀ #vr.63 )
                      case C2S_Receive
                      solve( splitEqs(8) )
                        case split
                        solve( splitEqs(10) )
                          case split
                          solve( !KU( aenc(<fido_rec, ~ltk_user>, pk(~ltk_user)) ) @ #vk.12 )
                            case Server_Sends_Recovery_Data_case_1
                            by contradiction /* from formulas */
                          next
                            case Server_Sends_Recovery_Data_case_2
                            solve( C2S_Rcv( $A.1, 'Server',
                                            <'3_store_pkg', pkA, sk2, encrypted_sk1, $B.2>
                                   ) ▶₀ #vr.77 )
                              case C2S_Receive
                              solve( C2S_Rcv( $A.1, 'Server', <'1_init_peer', $B.2> ) ▶₀ #vr.97 )
                                case C2S_Receive
                                solve( C2S_Rcv( $A.1, 'Server', <'1_init_peer', $B.3> ) ▶₀ #vr.98 )
                                  case C2S_Receive
                                  solve( C2S_Rcv( $A.1, 'Server', <'1_init_peer', $B.2> ) ▶₀ #vr.106 )
                                    case C2S_Receive
                                    solve( splitEqs(13) )
                                      case split
                                      by contradiction /* impossible chain */
                                    qed
                                  qed
                                qed
                              qed
                            qed
                          next
                            case Server_Sends_Recovery_Data_case_3
                            solve( C2S_Rcv( $A.1, 'Server',
                                            <'3_store_pkg', pkA, sk2, encrypted_sk1, $B.2>
                                   ) ▶₀ #vr.76 )
                              case C2S_Receive
                              solve( (#vr.73, 0) ~~> (#vk.1, 0) )
                                case d_0_adec
                                by contradiction /* impossible chain */
                              qed
                            qed
                          next
                            case c_aenc
                            solve( !KU( (~ltk_user⊕~sk1) ) @ #vk.14 )
                              case c_xor
                              solve( !KU( pk(~ltk_user) ) @ #vk.16 )
                                case Register_User
                                solve( !KU( ~ltk_user ) @ #vk.18 )
                                  case Reveal_Ltk_User
                                  by contradiction /* from formulas */
                                next
                                  case Server_Sends_Recovery_Data_case_1
                                  solve( C2S_Rcv( $A.1, 'Server',
                                                  <'3_store_pkg', pkA, sk2, encrypted_sk1, $B.2>
                                         ) ▶₀ #vr.77 )
                                    case C2S_Receive
