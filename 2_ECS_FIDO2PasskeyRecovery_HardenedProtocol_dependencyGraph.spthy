lemma secrecy_fido_key:
  all-traces
  "∀ A fido_key #i.
    (((A_Recovers_FIDO_Key( A, fido_key ) @ #i) ∧
      (¬(∃ #l. LtkRevealUser( A ) @ #l))) ∧
     (¬(∃ Peer #i_init #k_rev.
         (Initiated( A, Peer ) @ #i_init) ∧ (LtkRevealPeer( Peer ) @ #k_rev)))) ⇒
    (¬(∃ #z. K( fido_key ) @ #z))"
/*
guarded formula characterizing all counter-examples:
"∃ A fido_key #i.
  (A_Recovers_FIDO_Key( A, fido_key ) @ #i)
 ∧
  (∀ #l. (LtkRevealUser( A ) @ #l) ⇒ ⊥) ∧
  (∀ Peer #i_init #k_rev.
    (Initiated( A, Peer ) @ #i_init) ∧ (LtkRevealPeer( Peer ) @ #k_rev)
   ⇒
    ⊥) ∧
  (∃ #z. (K( fido_key ) @ #z))"
*/
simplify
solve( State_A_Recovered( $A, $B, aenc(x, pk(reconstructed_ltk)),
                          reconstructed_ltk
       ) ▶₀ #i )
  case Initiator_Reconstructs_PrivateKey
  solve( P2P_Rcv( $A, $B, <'7_p2p_help', ~nonce> ) ▶₀ #vr.8 )
    case P2P_Receive
    solve( C2S_Rcv( $A, 'Server', <'3_store_pkg', pkA, sk2.2, cipher, $B>
           ) ▶₀ #vr.18 )
      case C2S_Receive
      solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B> ) ▶₀ #vr.20 )
        case C2S_Receive
        solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B> ) ▶₀ #vr.30 )
          case C2S_Receive
          solve( splitEqs(1) )
            case split
            solve( splitEqs(3) )
              case split
              solve( !KU( ~nonce ) @ #vk.10 )
                case Server_Sends_Recovery_Data_case_1
                solve( C2S_Rcv( $A, 'Server',
                                <'3_store_pkg', pkA, sk2, encrypted_sk1, $B>
                       ) ▶₀ #vr.44 )
                  case C2S_Receive
                  solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B.1> ) ▶₀ #vr.55 )
                    case C2S_Receive
                    solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B> ) ▶₀ #vr.63 )
                      case C2S_Receive
                      solve( splitEqs(8) )
                        case split
                        solve( splitEqs(10) )
                          case split
                          solve( !KU( aenc(<fido_key, ~ltk_user>, pk(~ltk_user)) ) @ #vk.13 )
                            case Server_Sends_Recovery_Data_case_1
                            solve( C2S_Rcv( $A, 'Server',
                                            <'3_store_pkg', pkA, sk2, encrypted_sk1, $B.2>
                                   ) ▶₀ #vr.77 )
                              case C2S_Receive
                              solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B.2> ) ▶₀ #vr.96 )
                                case C2S_Receive
                                solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B.3> ) ▶₀ #vr.97 )
                                  case C2S_Receive
                                  solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B.2> ) ▶₀ #vr.105 )
                                    case C2S_Receive
                                    solve( splitEqs(13) )
                                      case split
                                      solve( splitEqs(14) )
                                        case split
                                        solve( splitEqs(15) )
                                          case split
                                          solve( !KU( (~ltk_user⊕~sk1) ) @ #vk.15 )
                                            case c_xor
                                            solve( !KU( ~fido_key ) @ #vk.11 )
                                              case Server_Sends_Recovery_Data_case_1
                                              solve( !KU( ~sk1 ) @ #vk.16 )
                                                case Server_Sends_Recovery_Data_case_1
                                                solve( C2S_Rcv( $A.1, 'Server',
                                                                <'3_store_pkg', pkA, sk2, encrypted_sk1, $B.4>
                                                       ) ▶₀ #vr.124 )
                                                  case C2S_Receive
                                                  solve( C2S_Rcv( $A.1, 'Server', <'1_init_peer', $B.4>
                                                         ) ▶₀ #vr.144 )
                                                    case C2S_Receive
                                                    solve( C2S_Rcv( $A.1, 'Server', <'1_init_peer', $B.5>
                                                           ) ▶₀ #vr.145 )
                                                      case C2S_Receive
                                                      solve( C2S_Rcv( $A.1, 'Server', <'1_init_peer', $B.4>
                                                             ) ▶₀ #vr.153 )
                                                        case C2S_Receive
                                                        solve( splitEqs(21) )
                                                          case split
                                                          solve( (#vr.121, 0) ~~> (#vk.4, 0) )
                                                            case d_xor_case_1
                                                            by solve( (#vr.163, 0) ~~> (#vk.4, 0) )
                                                          next
                                                            case d_xor_case_2
                                                            by solve( (#vr.163, 0) ~~> (#vk.4, 0) )
                                                          next
                                                            case d_xor_case_3
                                                            by solve( (#vr.163, 0) ~~> (#vk.4, 0) )
                                                          next
                                                            case d_xor_case_4
                                                            solve( (#vr.163, 0) ~~> (#vk.4, 0) )
                                                              case Var_fresh_1_sk1
                                                              solve( !KU( ~ltk_user ) @ #vk.17 )
                                                                case Reveal_Ltk_User
                                                                by contradiction /* from formulas */
                                                              next
                                                                case Server_Sends_Recovery_Data_case_1
                                                                solve( C2S_Rcv( $A.1, 'Server',
                                                                                <'3_store_pkg', pkA, sk2, 
                                                                                 encrypted_sk1, $B.5>
                                                                       ) ▶₀ #vr.157 )
                                                                  case C2S_Receive
                                                                  solve( C2S_Rcv( $A.1, 'Server',
                                                                                  <'1_init_peer', $B.5>
                                                                         ) ▶₀ #vr.177 )
                                                                    case C2S_Receive
                                                                    solve( C2S_Rcv( $A.1, 'Server',
                                                                                    <'1_init_peer', $B.6>
