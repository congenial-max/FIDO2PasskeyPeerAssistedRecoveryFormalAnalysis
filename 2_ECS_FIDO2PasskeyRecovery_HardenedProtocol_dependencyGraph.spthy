lemma secrecy_main_key:
  all-traces
  "∀ A ltk #i.
    (((A_Reconstructs_Key( A, ltk ) @ #i) ∧
      (¬(∃ #k. LtkRevealUser( A ) @ #k))) ∧
     (∀ B #k.
       (Initiated( A, B ) @ #k) ⇒ (¬(∃ #r. LtkRevealPeer( B ) @ #r)))) ⇒
    (¬(∃ #z. K( ltk ) @ #z))"
/*
guarded formula characterizing all counter-examples:
"∃ A ltk #i.
  (A_Reconstructs_Key( A, ltk ) @ #i)
 ∧
  (∀ #k. (LtkRevealUser( A ) @ #k) ⇒ ⊥) ∧
  (∀ B #k.
    (Initiated( A, B ) @ #k) ⇒ ∀ #r. (LtkRevealPeer( B ) @ #r) ⇒ ⊥) ∧
  (∃ #z. (K( ltk ) @ #z))"
*/
simplify
solve( !PkUser( $A, pk(ltk) ) ▶₁ #i )
  case Register_User
  solve( State_A_Recovery_4( $A, $B, sk1, sk2, encrypted_fido_key ) ▶₀ #i )
    case Initiator_Receives_Decrypted_Subkey
    solve( P2P_Rcv( $A, $B, <'7_p2p_help', ~nonce> ) ▶₀ #vr.7 )
