                                        case C2S_Receive
                                        solve( C2S_Rcv( $A.1, 'Server', <'1_init_peer', $B.2> ) ▶₀ #vr.106 )
                                          case C2S_Receive
                                          solve( splitEqs(13) )
                                            case split
                                            solve( (#vr.74, 0) ~~> (#vk.4, 0) )
                                              case d_xor_case_1
                                              by solve( (#vr.116, 0) ~~> (#vk.4, 0) )
                                            next
                                              case d_xor_case_2
                                              by solve( (#vr.116, 0) ~~> (#vk.4, 0) )
                                            next
                                              case d_xor_case_3
                                              solve( (#vr.116, 0) ~~> (#vk.4, 0) )
                                                case Var_fresh_1_ltk_user
                                                solve( !KU( ~sk1 ) @ #vk.19 )
                                                  case Server_Sends_Recovery_Data_case_1
                                                  solve( C2S_Rcv( $A.1, 'Server',
