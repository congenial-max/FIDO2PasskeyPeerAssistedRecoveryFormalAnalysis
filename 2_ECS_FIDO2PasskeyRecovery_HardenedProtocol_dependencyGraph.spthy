lemma isolation_guardian_user_key_compromise:
  all-traces
  "∀ A B sk1 nonce #i.
    (((((PeerHelpsRecovery( B, A, sk1, nonce ) @ #i) ∧
        (∃ #l. LtkRevealUser( B ) @ #l)) ∧
       (¬(∃ #l. LtkRevealPeer( B ) @ #l))) ∧
      (¬(∃ #l. LtkRevealUser( A ) @ #l))) ∧
     (¬(∃ Peer #i_init #k_rev.
         (Initiated( A, Peer ) @ #i_init) ∧ (LtkRevealPeer( Peer ) @ #k_rev)))) ⇒
    (¬(∃ #z. K( sk1 ) @ #z))"
/*
guarded formula characterizing all counter-examples:
"∃ A B sk1 nonce #i.
  (PeerHelpsRecovery( B, A, sk1, nonce ) @ #i)
 ∧
  (∃ #l. (LtkRevealUser( B ) @ #l)) ∧
  (∀ #l. (LtkRevealPeer( B ) @ #l) ⇒ ⊥) ∧
  (∀ #l. (LtkRevealUser( A ) @ #l) ⇒ ⊥) ∧
  (∀ Peer #i_init #k_rev.
    (Initiated( A, Peer ) @ #i_init) ∧ (LtkRevealPeer( Peer ) @ #k_rev)
   ⇒
    ⊥) ∧
  (∃ #z. (K( sk1 ) @ #z))"
*/
simplify
solve( !LtkPeer( $B, ltkPeerB ) ▶₂ #i )
  case Register_User
  solve( !LtkUser( $B, ltk ) ▶₀ #l )
    case Register_User
    solve( !StoredEncryptedSubkey( $B, $A, cipher ) ▶₁ #i )
      case Peer_Receives_Encrypted_Subkey
      solve( P2P_Rcv( $A, $B, <'7_p2p_help', nonce> ) ▶₀ #i )
        case P2P_Receive
        solve( C2S_Rcv( $A, 'Server', <'3_store_pkg', pkA, sk2, cipher, $B>
               ) ▶₀ #vr.4 )
          case C2S_Receive
