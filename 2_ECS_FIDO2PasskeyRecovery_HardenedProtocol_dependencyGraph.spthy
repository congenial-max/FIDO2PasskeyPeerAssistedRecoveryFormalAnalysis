theory ECS_FIDO2PasskeyRecovery_HardenedProtocol begin

// Function signature and definition of the equational theory E

builtins: xor
functions: adec/2, aenc/2, fst/1, pair/2, pk/1, qr_code/1, snd/1
equations:
    adec(aenc(x.1, pk(x.2)), x.2) = x.1,
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2



heuristic: o "FIDO2_Passkey_Recovery.oracle"





restriction Equality:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  // safety formula

restriction OneSetupPerUser:
  "∀ A pkU1 pkP1 pkU2 pkP2 #i #j.
    ((MainKeysGenerated( A, pkU1, pkP1 ) @ #i) ∧
     (MainKeysGenerated( A, pkU2, pkP2 ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

rule (modulo E) C2S_Send:
   [ C2S_Snd( A, B, m ) ] --> [ Sec_C2S( A, B, m ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) C2S_Receive:
   [ Sec_C2S( A, B, m ) ] --> [ C2S_Rcv( A, B, m ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) S2C_Send:
   [ S2C_Snd( A, B, m ) ] --> [ Sec_S2C( A, B, m ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) S2C_Receive:
   [ Sec_S2C( A, B, m ) ] --> [ S2C_Rcv( A, B, m ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) P2P_Send:
   [ P2P_Snd( A, B, m ) ] --> [ Sec_P2P( A, B, m ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) P2P_Receive:
   [ Sec_P2P( A, B, m ) ] --> [ P2P_Rcv( A, B, m ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Reveal_Ltk_User[color=#ffcccc]:
   [ !LtkUser( $A, ltk ) ] --[ LtkRevealUser( $A ) ]-> [ Out( ltk ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Reveal_Ltk_Peer[color=#ffccaa]:
   [ !LtkPeer( $A, ltk ) ] --[ LtkRevealPeer( $A ) ]-> [ Out( ltk ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Register_User:
   [ Fr( ~ltk_user ), Fr( ~ltk_peer ) ]
  --[
  MainKeysGenerated( $A, pk(~ltk_user), pk(~ltk_peer) ),
  UserRegistered( $A, 'Client' )
  ]->
   [
   !RegisteredUser( $A, 'Client' ), !LtkUser( $A, ~ltk_user ),
   !PkUser( $A, pk(~ltk_user) ), Out( pk(~ltk_user) ),
   !LtkPeer( $A, ~ltk_peer ), !PkPeer( $A, pk(~ltk_peer) ),
   Out( pk(~ltk_peer) )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Initiator_Sends_Peer_Name:
   [ !RegisteredUser( $A, 'Client' ), !RegisteredUser( $B, 'Client' ) ]
  --[ Initiated( $A, $B ) ]->
   [ C2S_Snd( $A, 'Server', <'1_init_peer', $B> ), State_A_1( $A, $B ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Initiator_Receives_Peer_Key:
   [
   State_A_1( $A, $B ),
   S2C_Rcv( 'Server', $A, <'2_server_resp', $B, pkPeerB> )
   ]
  --[ AReceivedPeerKey( $A, $B, pkPeerB ) ]->
   [ State_A_2( $A, $B, pkPeerB ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Initiator_Sends_Subkeys:
   [ State_A_2( $A, $B, pkPeerB ), !LtkUser( $A, ltkUserA ), Fr( ~sk1 ) ]
  --[
  ASendsKeyPackage( $A, $B,
                    <'3_store_pkg', pk(ltkUserA), (~sk1⊕ltkUserA), aenc(~sk1, pkPeerB), $B>,
                    aenc(~sk1, pkPeerB)
  )
  ]->
   [
   C2S_Snd( $A, 'Server',
            <'3_store_pkg', pk(ltkUserA), (~sk1⊕ltkUserA), aenc(~sk1, pkPeerB), $B>
   ),
   State_A_3( $A, $B, ltkUserA, pkPeerB, (~sk1⊕ltkUserA),
              aenc(~sk1, pkPeerB)
   )
   ]

  /*
  rule (modulo AC) Initiator_Sends_Subkeys:
     [ State_A_2( $A, $B, pkPeerB ), !LtkUser( $A, ltkUserA ), Fr( ~sk1 ) ]
    --[
    ASendsKeyPackage( $A, $B,
                      <'3_store_pkg', pk(ltkUserA), z, aenc(~sk1, pkPeerB), $B>,
                      aenc(~sk1, pkPeerB)
    )
    ]->
     [
     C2S_Snd( $A, 'Server',
              <'3_store_pkg', pk(ltkUserA), z, aenc(~sk1, pkPeerB), $B>
     ),
     State_A_3( $A, $B, ltkUserA, pkPeerB, z, aenc(~sk1, pkPeerB) )
     ]
    variants (modulo AC)
    1. ~sk1  = ~sk1.10
       ltkUserA
             = ~sk1.10
       z     = zero
    
    2. ~sk1  = ~sk1.10
       ltkUserA
             = zero
       z     = ~sk1.10
    
    3. ~sk1  = ~sk1.11
       ltkUserA
             = ltkUserA.12
       z     = (~sk1.11⊕ltkUserA.12)
    
    4. ~sk1  = ~sk1.15
       ltkUserA
             = (~sk1.15⊕z.20)
       z     = z.20
  */

rule (modulo E) Initiator_Starts_Phase2:
   [
   State_A_3( $A, $B, ltkUserA, pkPeerB, sk2, encrypted_sk1 ),
   Fr( ~fido_key ), !PkUser( $A, pkUserA )
   ]
  --[ A_Generates_FIDO_Key( $A, ~fido_key ) ]->
   [
   C2S_Snd( $A, 'Server',
            <'4_store_fido', aenc(<~fido_key, ltkUserA>, pkUserA)>
   ),
   State_A_4( $A, $B, ~fido_key )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Initiate_Recovery:
   [ State_A_4( $A, $B, fido_key ), Fr( ~nonce ) ]
  --[ A_Initiates_Recovery( $A, ~nonce ) ]->
   [
   C2S_Snd( $A, 'Server', <'5_req_recovery', $B, ~nonce> ),
   State_A_Recovery_1( $A, $B, ~nonce )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Initiator_Receives_Recovery_Data:
   [
   State_A_Recovery_1( $A, $B, nonce ),
   In( <'Server', $A, 'recovery_fido', nonce, encrypted_fido_key> ),
   In( <'Server', $A, 'recovery_package', nonce, sk2> )
   ]
  --[ AReceivedRecoveryData( $A, sk2, encrypted_fido_key ) ]->
   [ State_A_Recovery_2( $A, $B, sk2, encrypted_fido_key, nonce ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Initiator_Requests_Help_From_Peer:
   [ State_A_Recovery_2( $A, $B, sk2, encrypted_fido_key, nonce ) ]
  --[ ARequestsHelp( $A, $B ) ]->
   [
   P2P_Snd( $A, $B, <'7_p2p_help', nonce> ),
   State_A_Recovery_3( $A, $B, sk2, encrypted_fido_key, nonce )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Initiator_Receives_Decrypted_Subkey:
   [
   State_A_Recovery_3( $A, $B, sk2, encrypted_fido_key, nonce ),
   P2P_Rcv( $B, $A, qr_code(<sk1, nonce>) )
   ]
  --[
  AReceivedQR( $A, $B, qr_code(<sk1, nonce>) ),
  A_Receives_Decrypted_Subkey( $A, $B, sk1, nonce )
  ]->
   [ State_A_Recovery_4( $A, $B, sk1, sk2, encrypted_fido_key ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Initiator_Reconstructs_PrivateKey:
   [
   State_A_Recovery_4( $A, $B, sk1, sk2, encrypted_fido_key ),
   !PkUser( $A, pkUserA )
   ]
  --[ Eq( pk((sk1⊕sk2)), pkUserA ), A_Reconstructs_Key( $A, (sk1⊕sk2) ) ]->
   [ State_A_Recovered( $A, $B, encrypted_fido_key, (sk1⊕sk2) ) ]

  /*
  rule (modulo AC) Initiator_Reconstructs_PrivateKey:
     [
     State_A_Recovery_4( $A, $B, sk1, sk2, encrypted_fido_key ),
     !PkUser( $A, pkUserA )
     ]
    --[ Eq( pk(z), pkUserA ), A_Reconstructs_Key( $A, z ) ]->
     [ State_A_Recovered( $A, $B, encrypted_fido_key, z ) ]
    variants (modulo AC)
    1. sk1   = sk1.8
       sk2   = sk2.8
       z     = (sk1.8⊕sk2.8)
    
    2. sk1   = sk1.8
       sk2   = zero
       z     = sk1.8
    
    3. sk1   = x.8
       sk2   = x.8
       z     = zero
    
    4. sk1   = x.8
       sk2   = (x.8⊕x.9)
       z     = x.9
    
    5. sk1   = zero
       sk2   = sk2.8
       z     = sk2.8
    
    6. sk1   = (x.8⊕x.9)
       sk2   = x.8
       z     = x.9
    
    7. sk1   = (x.8⊕x.9)
       sk2   = (x.8⊕x.10)
       z     = (x.9⊕x.10)
  */

rule (modulo E) Initiator_Recovers_FIDO_Key:
   [ State_A_Recovered( $A, $B, encrypted_fido_key, reconstructed_ltk ) ]
  --[
  Eq( snd(adec(encrypted_fido_key, reconstructed_ltk)), reconstructed_ltk
  ),
  A_Recovers_FIDO_Key( $A, fst(adec(encrypted_fido_key, reconstructed_ltk))
  ),
  RecoveryComplete( $A, $B )
  ]->
   [ ]

  /*
  rule (modulo AC) Initiator_Recovers_FIDO_Key:
     [ State_A_Recovered( $A, $B, encrypted_fido_key, reconstructed_ltk ) ]
    --[
    Eq( z, reconstructed_ltk ), A_Recovers_FIDO_Key( $A, z.1 ),
    RecoveryComplete( $A, $B )
    ]->
     [ ]
    variants (modulo AC)
    1. encrypted_fido_key
             = encrypted_fido_key.7
       reconstructed_ltk
             = reconstructed_ltk.7
       z     = snd(adec(encrypted_fido_key.7, reconstructed_ltk.7))
       z.1   = fst(adec(encrypted_fido_key.7, reconstructed_ltk.7))
    
    2. encrypted_fido_key
             = aenc(x.7, pk(x.8))
       reconstructed_ltk
             = x.8
       z     = snd(x.7)
       z.1   = fst(x.7)
    
    3. encrypted_fido_key
             = aenc(<x.7, x.8>, pk(x.9))
       reconstructed_ltk
             = x.9
       z     = x.8
       z.1   = x.7
  */

rule (modulo E) Server_Sends_Peer_Key:
   [
   C2S_Rcv( $A, 'Server', <'1_init_peer', $B> ), !PkPeer( $B, pkPeerB ),
   !RegisteredUser( $A, 'Client' )
   ]
  --[ ServerResponds( $A, $B, pkPeerB ) ]->
   [ S2C_Snd( 'Server', $A, <'2_server_resp', $B, pkPeerB> ) ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Server_Receives_And_Forwards_Package:
   [ C2S_Rcv( $A, 'Server', <'3_store_pkg', pkA, sk2, encrypted_sk1, $B> ) ]
  --[
  ServerStoresPackage( $A, $B, pkA, sk2, encrypted_sk1 ),
  ServerForwardsSubkey( $A, $B, encrypted_sk1 )
  ]->
   [
   !StoredPackage( $A, $B, pkA, sk2, encrypted_sk1 ),
   S2C_Snd( 'Server', $B, <'subkey_package', $A, encrypted_sk1> )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Server_Receives_FIDO_Key:
   [ C2S_Rcv( $A, 'Server', <'4_store_fido', encrypted_fido_key> ) ]
  --[ ServerStoresFIDOKey( $A, encrypted_fido_key ) ]->
   [ !StoredFIDOKey( $A, encrypted_fido_key ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Server_Sends_Recovery_Data:
   [
   C2S_Rcv( $A, 'Server', <'5_req_recovery', $B, nonce> ),
   !StoredFIDOKey( $A, encrypted_fido_key ),
   !StoredPackage( $A, $B, pkA, sk2, encrypted_sk1 )
   ]
  --[ ServerSendsRecoveryData( $A, sk2, encrypted_fido_key ) ]->
   [
   Out( <'Server', $A, 'recovery_fido', nonce, encrypted_fido_key> ),
   Out( <'Server', $A, 'recovery_package', nonce, sk2> ),
   Out( <'Server', $A, 'subkey_package', encrypted_sk1> )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Peer_Receives_Encrypted_Subkey:
   [ S2C_Rcv( 'Server', $B, <'subkey_package', $A, cipher> ) ]
  --[ B_Stores_Subkey( $B, $A, cipher ) ]->
   [ !StoredEncryptedSubkey( $B, $A, cipher ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Peer_Decrypts_And_Sends_QR:
   [
   P2P_Rcv( $A, $B, <'7_p2p_help', nonce> ),
   !StoredEncryptedSubkey( $B, $A, cipher ), !LtkPeer( $B, ltkPeerB )
   ]
  --[ PeerHelpsRecovery( $B, $A, adec(cipher, ltkPeerB), nonce ) ]->
   [ P2P_Snd( $B, $A, qr_code(<adec(cipher, ltkPeerB), nonce>) ) ]

  // loop breaker: [0]
  /*
  rule (modulo AC) Peer_Decrypts_And_Sends_QR:
     [
     P2P_Rcv( $A, $B, <'7_p2p_help', nonce> ),
     !StoredEncryptedSubkey( $B, $A, cipher ), !LtkPeer( $B, ltkPeerB )
     ]
    --[ PeerHelpsRecovery( $B, $A, z, nonce ) ]->
     [ P2P_Snd( $B, $A, qr_code(<z, nonce>) ) ]
    variants (modulo AC)
    1. cipher
             = cipher.9
       ltkPeerB
             = ltkPeerB.10
       z     = adec(cipher.9, ltkPeerB.10)
    
    2. cipher
             = aenc(z.13, pk(ltkPeerB.10))
       ltkPeerB
             = ltkPeerB.10
       z     = z.13
    // loop breaker: [0]
  */

lemma protocol_is_executable_strong:
  exists-trace
  "∃ A B #i.
    ((RecoveryComplete( A, B ) @ #i) ∧
     (¬(∃ User #k. LtkRevealUser( User ) @ #k))) ∧
    (¬(∃ User #k. LtkRevealPeer( User ) @ #k))"
/*
guarded formula characterizing all satisfying traces:
"∃ A B #i.
  (RecoveryComplete( A, B ) @ #i)
 ∧
  (∀ User #k. (LtkRevealUser( User ) @ #k) ⇒ ⊥) ∧
  (∀ User #k. (LtkRevealPeer( User ) @ #k) ⇒ ⊥)"
*/
simplify
solve( State_A_Recovered( $A, $B, aenc(x, pk(reconstructed_ltk)),
                          reconstructed_ltk
       ) ▶₀ #i )
  case Initiator_Reconstructs_PrivateKey
  solve( P2P_Rcv( $A, $B, <'7_p2p_help', ~nonce> ) ▶₀ #vr.8 )
    case P2P_Receive
    solve( C2S_Rcv( $A, 'Server', <'3_store_pkg', pkA, sk2.2, cipher, $B>
           ) ▶₀ #vr.18 )
      case C2S_Receive
      solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B> ) ▶₀ #vr.20 )
        case C2S_Receive
        solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B> ) ▶₀ #vr.30 )
          case C2S_Receive
          solve( splitEqs(1) )
            case split
            solve( splitEqs(3) )
              case split
              solve( !KU( ~nonce ) @ #vk.9 )
                case Server_Sends_Recovery_Data_case_1
                solve( C2S_Rcv( $A, 'Server',
                                <'3_store_pkg', pkA, sk2, encrypted_sk1, $B>
                       ) ▶₀ #vr.44 )
                  case C2S_Receive
                  solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B.1> ) ▶₀ #vr.55 )
                    case C2S_Receive
                    solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B> ) ▶₀ #vr.63 )
                      case C2S_Receive
                      solve( splitEqs(8) )
                        case split
                        solve( splitEqs(10) )
                          case split
                          solve( !KU( aenc(<z, ~ltk_user>, pk(~ltk_user)) ) @ #vk.12 )
                            case Server_Sends_Recovery_Data_case_1
                            solve( C2S_Rcv( $A, 'Server',
                                            <'3_store_pkg', pkA, sk2, encrypted_sk1, $B.2>
                                   ) ▶₀ #vr.77 )
                              case C2S_Receive
                              solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B.2> ) ▶₀ #vr.96 )
                                case C2S_Receive
                                solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B.3> ) ▶₀ #vr.97 )
                                  case C2S_Receive
                                  solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B.2> ) ▶₀ #vr.105 )
                                    case C2S_Receive
                                    solve( splitEqs(13) )
                                      case split
                                      solve( splitEqs(14) )
                                        case split
                                        solve( splitEqs(15) )
                                          case split
                                          solve( !KU( (~ltk_user⊕~sk1) ) @ #vk.14 )
                                            case coerce
                                            solve( !KD( (~ltk_user⊕~sk1) ) ▶₀ #vk.2 )
                                              case Server_Sends_Recovery_Data_case_2
                                              solve( !StoredFIDOKey( $A.1, encrypted_fido_key ) ▶₁ #vr.115 )
                                                case Server_Receives_FIDO_Key
                                                solve( !StoredPackage( $A.1, $B.4, pkA, sk2, encrypted_sk1
                                                       ) ▶₂ #vr.115 )
                                                  case Server_Receives_And_Forwards_Package
                                                  solve( (#vl.2, 0) ~~> (#vk.2, 0) )
                                                    case d_0_snd
                                                    solve( C2S_Rcv( $A.1, 'Server',
                                                                    <'5_req_recovery', $B.4, nonce.2>
                                                           ) ▶₀ #vr.115 )
                                                      case C2S_Receive
                                                      solve( C2S_Rcv( $A.1, 'Server', <'1_init_peer', $B.5>
                                                             ) ▶₀ #vr.127 )
                                                        case C2S_Receive
                                                        solve( C2S_Rcv( $A.1, 'Server',
                                                                        <'3_store_pkg', pkA, sk2, 
                                                                         encrypted_sk1, $B.4>
                                                               ) ▶₀ #vr.128 )
                                                          case C2S_Receive
                                                          solve( (#vr.129, 0) ~~> (#vk.2, 0) )
                                                            case d_0_snd
                                                            solve( C2S_Rcv( $A.1, 'Server',
                                                                            <'1_init_peer', $B.4>
                                                                   ) ▶₀ #vr.140 )
                                                              case C2S_Receive
                                                              solve( C2S_Rcv( $A.1, 'Server',
                                                                              <'1_init_peer', $B.4>
                                                                     ) ▶₀ #vr.151 )
                                                                case C2S_Receive
                                                                solve( (#vr.152, 0) ~~> (#vk.2, 0) )
                                                                  case d_0_snd
                                                                  solve( (#vr.159, 0) ~~> (#vk.2, 0) )
                                                                    case d_0_snd
                                                                    solve( splitEqs(20) )
                                                                      case split
                                                                      solve( splitEqs(21) )
                                                                        case split
                                                                        solve( splitEqs(22) )
                                                                          case split
                                                                          solve( (#vr.160, 0) ~~> (#vk.2, 0) )
                                                                            case Xor
                                                                            SOLVED // trace found
                                                                          qed
                                                                        qed
                                                                      qed
                                                                    qed
                                                                  qed
                                                                qed
                                                              qed
                                                            qed
                                                          qed
                                                        qed
                                                      qed
                                                    qed
                                                  qed
                                                qed
                                              qed
                                            qed
                                          qed
                                        qed
                                      qed
                                    qed
                                  qed
                                qed
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma secrecy_peer_share_sk1:
  all-traces
  "∀ A B sk1 nonce #i.
    (((PeerHelpsRecovery( B, A, sk1, nonce ) @ #i) ∧
      (¬(∃ #k. LtkRevealUser( A ) @ #k))) ∧
     (¬(∃ Peer #i_init #k_rev.
         (Initiated( A, Peer ) @ #i_init) ∧ (LtkRevealPeer( Peer ) @ #k_rev)))) ⇒
    (¬(∃ #z. K( sk1 ) @ #z))"
/*
guarded formula characterizing all counter-examples:
"∃ A B sk1 nonce #i.
  (PeerHelpsRecovery( B, A, sk1, nonce ) @ #i)
 ∧
  (∀ #k. (LtkRevealUser( A ) @ #k) ⇒ ⊥) ∧
  (∀ Peer #i_init #k_rev.
    (Initiated( A, Peer ) @ #i_init) ∧ (LtkRevealPeer( Peer ) @ #k_rev)
   ⇒
    ⊥) ∧
  (∃ #z. (K( sk1 ) @ #z))"
*/
simplify
solve( !LtkPeer( $B, ltkPeerB ) ▶₂ #i )
  case Register_User
  solve( !StoredEncryptedSubkey( $B, $A, cipher ) ▶₁ #i )
    case Peer_Receives_Encrypted_Subkey
    solve( P2P_Rcv( $A, $B, <'7_p2p_help', nonce> ) ▶₀ #i )
      case P2P_Receive
      solve( C2S_Rcv( $A, 'Server', <'3_store_pkg', pkA, sk2, cipher, $B>
             ) ▶₀ #vr.4 )
        case C2S_Receive
        solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B> ) ▶₀ #vr.17 )
          case C2S_Receive
          solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B> ) ▶₀ #vr.25 )
            case C2S_Receive
            solve( splitEqs(1) )
              case split
              solve( splitEqs(2) )
                case split
                solve( !KU( ~nonce ) @ #vk.10 )
                  case Server_Sends_Recovery_Data_case_1
                  solve( C2S_Rcv( $A, 'Server',
                                  <'3_store_pkg', pkA, sk2.1, encrypted_sk1, $B>
                         ) ▶₀ #vr.39 )
                    case C2S_Receive
                    solve( C2S_Rcv( $A, 'Server', <'1_init_peer', $B.1> ) ▶₀ #vr.50 )
                      case C2S_Receive
