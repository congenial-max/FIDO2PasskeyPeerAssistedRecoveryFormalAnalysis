                                                        solve( C2S_Rcv( $A.1, 'Server', <'1_init_peer', $B.4>
                                                               ) ▶₀ #vr.152 )
                                                          case C2S_Receive
                                                          solve( splitEqs(17) )
                                                            case split
                                                            solve( (#vr.120, 0) ~~> (#vk.5, 0) )
                                                              case d_xor_case_1
                                                              by solve( (#vr.162, 0) ~~> (#vk.5, 0) )
                                                            next
